{
  "appId": "com.discordlite.app",
  "appName": "Discord Lite",
  "webDir": "build",
  "server": {
    "url": "https://discord-lite-client.vercel.app",
    "cleartext": true,
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1e1f22",
      "showSpinner": false
    }
  }
}
